# =============================================
# Keep only essential project files
# =============================================

# Keep these files (but they're already excluded above by type)
# We'll explicitly include them if needed via .gitignore rules

# Exclude all experiment outputs, but keep the directory structure
!results/.gitkeep
!outputs/.gitkeep
!logs/.gitkeep

# =============================================
# Optional: Exclude large directories
# =============================================

